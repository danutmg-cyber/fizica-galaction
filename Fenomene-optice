<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>FIZICĂ - FENOMENE OPTICE</title>
    <link rel="icon" type="image/png" href="https://img.icons8.com/fluency/48/light.png">
    <style>
        :root { --primary: #7c3aed; --bg: #0f172a; --card: #1e293b; --text: #f8fafc; --accent: #a78bfa; }
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; margin: 0; padding: 15px; }
        .header { text-align: center; width: 100%; max-width: 700px; border-bottom: 2px solid var(--primary); margin-bottom: 20px; padding-bottom: 10px; }
        .timer-bar { background: #334155; height: 10px; border-radius: 5px; width: 100%; margin: 10px 0; overflow: hidden; }
        #timer-progress { background: var(--accent); height: 100%; width: 100%; transition: width 1s linear; }
        .container { width: 100%; max-width: 650px; background: var(--card); border-radius: 20px; padding: 25px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); border: 1px solid #334155; }
        .question-box { font-size: 1.2rem; font-weight: 500; margin-bottom: 10px; text-align: center; min-height: 60px; }
        .instruction-box { font-size: 0.95rem; color: #fbbf24; text-align: center; margin-bottom: 15px; font-weight: bold; display: none; background: rgba(251, 191, 36, 0.1); padding: 8px; border-radius: 8px; }
        .option-btn { background: #2d3748; border: 2px solid #4a5568; padding: 12px; border-radius: 12px; cursor: pointer; color: white; font-size: 1rem; transition: 0.2s; width: 100%; margin-bottom: 8px; text-align: left; }
        .option-btn:hover:not(:disabled) { border-color: var(--primary); background: #334155; }
        input[type="text"] { width: 100%; padding: 15px; border-radius: 12px; border: 2px solid #4a5568; background: #0f172a; color: white; font-size: 1.2rem; text-align: center; margin-bottom: 10px; }
        .check-btn { width: 100%; background: var(--primary); color: white; border: none; padding: 16px; border-radius: 12px; font-weight: bold; cursor: pointer; text-transform: uppercase; }
        #feedback { margin: 15px 0; padding: 15px; border-radius: 12px; display: none; text-align: center; font-weight: bold; }
        .next-btn { width: 100%; background: #059669; color: white; border: none; padding: 16px; border-radius: 12px; font-weight: bold; cursor: pointer; margin-top: 10px; display: none; }
        .hidden { display: none; }
    </style>
</head>
<body>

    <div class="header">
        <div style="font-size: 1.1rem; font-weight: bold; color: var(--accent);">🏫 GALA GALACTION MANGALIA</div>
        <div style="font-size: 0.9rem; color: #94a3b8;">TIMP RĂMAS: <span id="timer-text">50:00</span></div>
        <div class="timer-bar"><div id="timer-progress"></div></div>
    </div>

    <div class="container" id="screen-login">
        <h2 style="text-align:center;">💡 Fenomene Optice</h2>
        <p style="text-align:center; color:#94a3b8;">30 întrebări | Clasa a VIII-a</p>
        <input type="text" id="p-name" placeholder="Numele tău complet">
        <select id="p-class" style="width:100%; padding:15px; margin: 15px 0; border-radius:12px; background:#0f172a; color:white; border: 2px solid #4a5568;">
            <option value="">Selectează clasa...</option>
            <option value="8A">Clasa a VIII-a A</option><option value="8B">Clasa a VIII-a B</option>
            <option value="8C">Clasa a VIII-a C</option>
        </select>
        <button class="check-btn" onclick="startGame()">START TEST</button>
    </div>

    <div class="container hidden" id="screen-game">
        <div id="q-info" style="color: var(--accent); font-weight: bold; text-align: center; margin-bottom: 5px;"></div>
        <div class="question-box" id="question"></div>
        <div id="instruction" class="instruction-box">📝 Calculează rezultatul corect!</div>
        <div id="input-area"></div>
        <div id="feedback"></div>
        <button class="next-btn" id="next-btn" onclick="nextQuestion()">URMĂTOAREA ➡️</button>
    </div>

    <div class="container hidden" id="screen-end">
        <h2 style="text-align:center;">REZULTAT FINAL</h2>
        <div style="font-size: 5rem; color: var(--accent); font-weight: bold; text-align: center;" id="final-score"></div>
        <p style="text-align:center; color: #94a3b8;" id="raw-points"></p>
        <button class="check-btn" onclick="location.reload()">REIA TESTUL</button>
    </div>

<script>
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbzRIy0kI7SsJ9e9bD_UT2aH4htyB8vvDF0PUBwPPodz3xWJHc9Abky2E7FuvWK-1QGA/exec"; 
    let state = { name: "", class: "", correctAnswers: 0, currentIdx: 0, questions: [], timeLeft: 3000 };
    let timerInterval;

    const theoryPool = [
        { q: "Corpul care lasă să treacă toată lumina prin el se numește ...........", type: "fill", a: ["transparent"] },
        { q: "Unghiul de incidență este egal cu unghiul de reflexie. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Viteza luminii în vid este de aproximativ ........... km/s.", type: "fill", a: ["300000"] },
        { q: "Oglinda plană formează o imagine virtuală și simetrică. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Schimbarea direcției luminii la trecerea dintr-un mediu în altul se numește ...........", type: "fill", a: ["refractie"] },
        { q: "Lentila convergentă este mai subțire la mijloc decât la margini. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Fals" },
        { q: "Punctul în care converg razele paralele după trecerea prin lentilă se numește ...........", type: "fill", a: ["focar"] },
        { q: "Convergența unei lentile se măsoară în ...........", type: "fill", a: ["dioptrii"] },
        { q: "Ochiul miop folosește pentru corecție lentile divergente. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Curcubeul apare datorită fenomenului de ........... a luminii.", type: "fill", a: ["dispersie"] },
        { q: "Lumina albă este compusă din 7 culori spectrale. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Imaginea formată pe retina ochiului este răsturnată. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Distanța focală este inversul convergenței. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Indicele de refracție al vidului este egal cu ...........", type: "fill", a: ["1"] },
        { q: "Reflexia totală poate apărea doar la trecerea într-un mediu mai puțin optic. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Lentila divergentă transformă un fascicul paralel într-unul divergent. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" },
        { q: "Focarul unei lentile divergente este un focar virtual. (A/F)", type: "choice", o: ["Adevărat", "Fals"], a: "Adevărat" }
    ];

    function generateMathProblems() {
        const p = [];
        // Convergența C = 1/f
        let f1 = (Math.floor(Math.random() * 4) + 1) * 0.2; // 0.2, 0.4 etc
        p.push({ q: `Calculați convergența (C) a unei lentile cu distanța focală f = ${f1} m.`, type: "math", a: [(1/f1).toFixed(2)] });
        // Unghiuri
        let i2 = Math.floor(Math.random() * 40) + 10;
        p.push({ q: `Dacă unghiul dintre raza incidentă și oglindă este de ${i2}°, cât este unghiul de reflexie?`, type: "math", a: [(90 - i2).toString()] });
        return p;
    }

    function startGame() {
        state.name = document.getElementById('p-name').value.trim();
        state.class = document.getElementById('p-class').value;
        if(!state.name || !state.class) return alert("Completează datele!");
        const maths = generateMathProblems();
        const theory = theoryPool.sort(() => 0.5 - Math.random()).slice(0, 28);
        state.questions = [...theory, ...maths].sort(() => 0.5 - Math.random());
        document.getElementById('screen-login').classList.add('hidden');
        document.getElementById('screen-game').classList.remove('hidden');
        timerInterval = setInterval(updateTimer, 1000);
        showQuestion();
    }

    function showQuestion() {
        const q = state.questions[state.currentIdx];
        document.getElementById('q-info').innerText = `ÎNTREBAREA ${state.currentIdx + 1} / 30`;
        document.getElementById('question').innerText = q.q;
        document.getElementById('instruction').style.display = (q.type === 'math') ? 'block' : 'none';
        const area = document.getElementById('input-area');
        area.innerHTML = '';
        document.getElementById('feedback').style.display = 'none';
        document.getElementById('next-btn').style.display = 'none';
        if(q.type === 'choice') {
            const opts = q.o.includes("Adevărat") ? ["Adevărat", "Fals"] : q.o.sort(() => 0.5 - Math.random());
            opts.forEach(opt => {
                const b = document.createElement('button');
                b.className = 'option-btn'; b.innerText = opt;
                b.onclick = () => checkAns(opt);
                area.appendChild(b);
            });
        } else {
            area.innerHTML = `<input type="text" id="user-ans" placeholder="Răspuns..."><button class="check-btn" onclick="checkAns(document.getElementById('user-ans').value)">VERIFICĂ</button>`;
        }
    }

    function checkAns(user) {
        const q = state.questions[state.currentIdx];
        let isCorrect = false;
        if (q.type === 'math') {
            const userNum = parseFloat(user.toString().replace(",", "."));
            const targetNum = parseFloat(q.a[0]);
            isCorrect = !isNaN(userNum) && Math.abs(userNum - targetNum) < 0.01;
        } else if (q.type === 'fill') {
            const clean = (s) => s.toString().toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
            isCorrect = q.a.some(ans => clean(user) === clean(ans));
        } else { isCorrect = user === q.a; }
        const f = document.getElementById('feedback');
        f.style.display = 'block';
        if(isCorrect) { state.correctAnswers++; f.innerText = "CORECT! ✅"; f.style.color = "#4ade80"; }
        else { f.innerText = `GREȘIT! Răspuns: ${Array.isArray(q.a) ? q.a[0] : q.a} ❌`; f.style.color = "#f87171"; }
        document.querySelectorAll('.option-btn, .check-btn').forEach(b => b.disabled = true);
        document.getElementById('next-btn').style.display = 'block';
    }

    function nextQuestion() {
        state.currentIdx++;
        if(state.currentIdx < 30) showQuestion(); else finishGame();
    }

    function updateTimer() {
        if (state.timeLeft <= 0) { clearInterval(timerInterval); finishGame(); return; }
        state.timeLeft--;
        const mins = Math.floor(state.timeLeft / 60);
        const secs = state.timeLeft % 60;
        document.getElementById('timer-text').innerText = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
        document.getElementById('timer-progress').style.width = (state.timeLeft / 3000 * 100) + "%";
    }

    function finishGame() {
        clearInterval(timerInterval);
        document.getElementById('screen-game').classList.add('hidden');
        document.getElementById('screen-end').classList.remove('hidden');
        const nota = (1 + (state.correctAnswers * 0.3)).toFixed(2);
        document.getElementById('final-score').innerText = nota > 10 ? "10.00" : nota;
        document.getElementById('raw-points').innerText = `Ai obținut ${state.correctAnswers} puncte din 30.`;
        const fd = new FormData();
        fd.append("nume", state.name); fd.append("clasa", state.class); fd.append("scor", nota);
        fetch(SCRIPT_URL, { method: 'POST', body: fd, mode: 'no-cors' });
    }
</script>
</body>
</html>
